---
interface Props {
  name: string;
  description: string;
  prompt: string;
}

const { name, description, prompt } = Astro.props;
---

<article class="registry-chassis system-pillar">
  <div class="pillar-header">
    <div class="registry-annotation">
      <span class="registry-key">PILLAR_ID</span>: <span class="registry-value">{name.toUpperCase().replace(/\s/g, '_')}</span>
    </div>
  </div>
  
  <div class="pillar-content">
    <h3 class="pillar-title">{name}</h3>
    <p class="pillar-desc">{description}</p>
    
    <div class="focus-block">
      <div class="registry-annotation" style="margin-bottom: 0.5rem;">
        <span class="registry-key">FRAMEWORK_FOCUS</span>
      </div>
      <p class="focus-text">{prompt}</p>
    </div>
  </div>
</article>

<style>
  .system-pillar {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
  }
  .pillar-header {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--current-line);
  }
  .pillar-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0 0 1rem 0;
    letter-spacing: -0.01em;
    color: var(--current-text);
  }
  .pillar-desc {
    font-size: 1.05rem;
    color: var(--current-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .focus-block {
    padding: 1.25rem;
    border-left: 2px solid var(--accent-signal);
    background-color: rgba(59, 130, 246, 0.03);
  }
  .focus-text {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--current-text);
  }
</style>
