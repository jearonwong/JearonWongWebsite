---
import { siteConfig } from "../data/site";

const navItems = [
  { href: "/essays", label: "REGISTRY" },
  { href: "/theory-clusters", label: "BLUEPRINT" },
  { href: "/playbooks", label: "METHODS" },
  { href: "/projects", label: "LEDGER" },
  { href: "/about", label: "SPEC" }
];
---

<header class="site-monitor-container">
  <div class="shell monitor-shell registry-chassis">
    <div class="logo">
      <a href="/" class="logo-link">
        <div class="registry-annotation">
          <span class="registry-key">SITE_ID</span>: <span class="registry-value">ARCHITECT.OS</span>
        </div>
      </a>
    </div>
    
    <nav class="nav-desktop">
      <ul class="nav-list">
        {navItems.map(item => (
          <li class="nav-item">
            <a href={item.href} class="nav-link registry-annotation">
              <span class="registry-value">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <a href="/contact" class="nav-cta registry-annotation">
        <span class="registry-key">CMD</span>: <span class="registry-value">CONNECT</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-monitor-container {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    z-index: 1000;
  }
  .monitor-shell {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 2rem;
    background: rgba(17, 17, 17, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-registry);
  }
  
  .nav-list {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    transition: opacity 0.2s ease;
  }
  
  .nav-link:hover {
    opacity: 0.7;
  }

  .nav-cta {
    padding: 0.4rem 1rem;
    border: 1px solid var(--accent-signal);
    border-radius: var(--radius-module);
    transition: all 0.2s ease;
  }
  .nav-cta:hover {
    background: var(--accent-signal);
    color: white;
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
  }
</style>
