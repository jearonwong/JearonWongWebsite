---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import SocialShare from "../components/SocialShare.astro";
import {
  definitions,
  definitionSections,
  getDefinitionsBySection
} from "../data/definitions";
import { pageRegistry, siteConfig } from "../data/site";

const canonicalPath = "/definitions/";
const definitionsUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();

const definedTermSetJsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "@id": `${siteConfig.siteUrl}/definitions/#defined-term-set`,
  name: pageRegistry.definitions.title,
  description: pageRegistry.definitions.lead,
  url: definitionsUrl,
  creator: {
    "@id": `${siteConfig.siteUrl}#person`
  },
  hasDefinedTerm: definitions.map((entry) => ({
    "@type": "DefinedTerm",
    "@id": `${siteConfig.siteUrl}/definitions/#${entry.slug}`,
    name: entry.term,
    description: entry.definition,
    url: `${siteConfig.siteUrl}/definitions/#${entry.slug}`
  }))
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteConfig.siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: pageRegistry.definitions.title,
      item: definitionsUrl
    }
  ]
};
---

<BaseLayout
  title={pageRegistry.definitions.title}
  description={pageRegistry.definitions.lead}
  canonicalPath={canonicalPath}
  shareTitle="Definitions for the Agent Era — Jearon Wong"
  shareDescription={pageRegistry.definitions.lead}
  jsonLd={[definedTermSetJsonLd, breadcrumbJsonLd]}
>
  <RegistryPageHero
    title={pageRegistry.definitions.title}
    objectType={pageRegistry.definitions.objectType}
    objectValue={pageRegistry.definitions.objectValue}
    lead={pageRegistry.definitions.lead}
  />

  <div class="zone-b page-body definitions-body">
    <div class="shell definitions-shell">

      <section class="definitions-usage registry-chassis">
        <div class="registry-annotation" style="margin-bottom: 0.75rem;">
          <span class="registry-key">CITATION_FORMAT</span>: <span class="registry-value">URL/DEFINITIONS/#SLUG</span>
        </div>
        <p class="usage-note">
          Each entry has a stable anchor. Use <code>/definitions/#term-slug</code> as a permanent citation URL. The anchors do not change after publication.
        </p>
        <div class="usage-links">
          <a href="/lifecycle/">Lifecycle field analysis</a>
          <a href="/concepts/">Concepts reference layer</a>
        </div>
      </section>

      {definitionSections.map((sectionMeta) => {
        const sectionEntries = getDefinitionsBySection(sectionMeta.section);
        return (
          <section class="definitions-section" id={sectionMeta.id}>
            <div class="section-header">
              <div class="registry-annotation" style="margin-bottom: 0.65rem;">
                <span class="registry-key">{sectionMeta.tag}</span>
              </div>
              <h2>{sectionMeta.heading}</h2>
            </div>
            <div class="definition-ledger">
              {sectionEntries.map((entry, index) => (
                <article class="definition-entry" id={entry.slug}>
                  <div class="entry-header">
                    <span class="entry-index">{String(index + 1).padStart(2, "0")}</span>
                    <h3 class="entry-term">{entry.term}</h3>
                  </div>
                  <p class="entry-definition">{entry.definition}</p>
                  <div class="entry-distinction">
                    <span class="distinction-label">NOT:</span>
                    <p class="distinction-text">{entry.distinction}</p>
                  </div>
                  <div class="entry-links">
                    {entry.evidence.length > 0 && (
                      <div class="link-group">
                        <span class="link-group-label">Evidence</span>
                        {entry.evidence.map((e) => (
                          <a href={e.href} class="entry-link">{e.label}</a>
                        ))}
                      </div>
                    )}
                    {entry.related.length > 0 && (
                      <div class="link-group">
                        <span class="link-group-label">Related</span>
                        {entry.related.map((r) => (
                          <a href={r.href} class="entry-link entry-link--related">{r.label}</a>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </section>
        );
      })}

      <SocialShare
        title="Definitions for the Agent Era"
        description={pageRegistry.definitions.lead}
        url={definitionsUrl}
      />
    </div>
  </div>
</BaseLayout>

<style>
  .definitions-body {
    padding: var(--space-page-y) 0;
  }

  .definitions-shell {
    display: grid;
    gap: 3rem;
    min-width: 0;
  }

  .definitions-usage {
    padding: var(--registry-panel-padding);
    min-width: 0;
  }

  .usage-note {
    margin: 0 0 1rem;
    color: var(--current-muted);
    font-size: 0.98rem;
    line-height: 1.68;
    max-width: 62rem;
  }

  .usage-note code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--accent-signal);
    background: rgba(59, 130, 246, 0.08);
    padding: 0.1em 0.38em;
    border-radius: 2px;
  }

  .usage-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .usage-links a {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .usage-links a:hover {
    color: var(--current-text);
  }

  .definitions-section {
    display: grid;
    gap: 1.15rem;
    min-width: 0;
  }

  .section-header {
    max-width: 60rem;
    min-width: 0;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 760;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .definition-ledger {
    border: 1px solid var(--current-border);
    background: var(--current-surface);
    min-width: 0;
  }

  .definition-entry {
    display: grid;
    gap: 1.1rem;
    padding: var(--registry-panel-padding);
    border-bottom: 1px solid var(--current-line);
    border-left: 3px solid var(--accent-proof);
    min-width: 0;
  }

  .definition-entry:last-child {
    border-bottom: none;
  }

  .entry-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .entry-index {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: var(--accent-proof);
    flex-shrink: 0;
  }

  .entry-term {
    margin: 0;
    font-size: clamp(1.18rem, 2vw, 1.5rem);
    font-weight: 760;
    letter-spacing: -0.02em;
    line-height: 1.12;
    color: var(--current-text);
    min-width: 0;
  }

  .entry-definition {
    margin: 0;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    font-weight: 680;
    line-height: 1.56;
    color: var(--current-text);
    max-width: 68rem;
  }

  .entry-distinction {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    border-left: 2px solid var(--current-border);
    background: rgba(255, 255, 255, 0.02);
    min-width: 0;
  }

  .distinction-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: var(--current-muted);
    text-transform: uppercase;
    padding-top: 0.18rem;
  }

  .distinction-text {
    margin: 0;
    font-size: 0.93rem;
    line-height: 1.65;
    color: var(--current-muted);
    min-width: 0;
  }

  .entry-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 2rem;
    min-width: 0;
  }

  .link-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 0.8rem;
    min-width: 0;
  }

  .link-group-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--current-muted);
  }

  .entry-link {
    font-family: var(--font-mono);
    font-size: 0.73rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .entry-link:hover {
    color: var(--current-text);
  }

  .entry-link--related {
    color: var(--current-muted);
  }

  .entry-link--related:hover {
    color: var(--accent-signal);
  }

  @media (max-width: 980px) {
    .definitions-shell {
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .definitions-body {
      padding: var(--space-section-y-mobile) 0;
    }

    .definitions-shell {
      gap: 2rem;
    }

    .definitions-usage,
    .definition-entry {
      padding: var(--registry-card-padding);
    }

    .entry-distinction {
      grid-template-columns: 2.75rem 1fr;
      gap: 0.5rem;
      padding: 0.7rem 0.8rem;
    }

    .entry-links {
      gap: 0.7rem 1.25rem;
    }
  }
</style>
