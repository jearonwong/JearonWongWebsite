---
import { siteConfig } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<BaseLayout title={`Methods | ${siteConfig.title}`}>
  <div class="zone-a registry-grid" style="padding-top: 10rem; padding-bottom: 6rem; border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    <div class="shell">
      <div class="registry-annotation" style="margin-bottom: 1rem;">
        <span class="registry-key">OBJECT_TYPE</span>: <span class="registry-value">OPERATING_METHODS_APPENDIX</span>
      </div>
      <h1 style="font-size: 4rem; font-weight: 800; letter-spacing: -0.04em;">METHODS</h1>
      <p class="lead" style="max-width: 50ch;">Structured methods and repeatable frameworks for orchestrating AI agent systems.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis" style="padding: 4rem;">
        <div class="registry-annotation" style="margin-bottom: 2rem;">
          <span class="registry-key">APPENDIX_ID</span>: <span class="registry-value">METHOD_PLAYBOOK_01</span>
        </div>
        <div class="prose" style="max-width: 65ch; font-size: 1.1rem; line-height: 1.7; color: var(--current-muted);">
          <p>Methods are the executable logic of the protocol. They describe the specific sequences of action, verification, and correction that lead to reliable work output.</p>
          <div class="registry-chassis" style="margin-top: 3rem; padding: 2rem; border-left: 2px solid var(--accent-caution);">
             <div class="registry-annotation" style="margin-bottom: 0.5rem;">
               <span class="registry-key">STATUS</span>: <span class="registry-value">DOCUMENTATION_IN_PROGRESS</span>
             </div>
             <p style="margin: 0;">Playbooks are currently being documented and refined inside the SoloCrew operational environment.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
