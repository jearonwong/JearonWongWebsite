---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<BaseLayout title="Playbooks">
  <div class="zone-a">
    <SiteHeader />
    <section class="shell page-header">
      <span class="eyebrow">Playbooks</span>
      <h1 class="page-title">Operating Methods.</h1>
      <p class="lead">
        Structured methods and repeatable frameworks for orchestrating AI agent systems.
      </p>
    </section>
  </div>
  <div class="zone-b page-body">
    <section class="shell section-rhythm">
      <div class="structural-panel">
        <p class="lead">Playbooks are currently being documented and refined inside the SoloCrew operational environment.</p>
        <span class="badge">Checking in shortly</span>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }
  .page-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    max-width: 16ch;
    letter-spacing: -0.04em;
  }
  .structural-panel {
    background-color: transparent;
    border: 1px solid var(--current-border);
    border-radius: var(--radius-sm);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
</style>
