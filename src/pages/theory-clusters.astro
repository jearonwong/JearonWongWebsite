---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { theoryClusters } from "../data/site";

const essays = (await getCollection("essays")).sort(
  (left, right) => right.data.publishDate.getTime() - left.data.publishDate.getTime()
);

const clusters = theoryClusters.map((cluster) => ({
  ...cluster,
  essays: essays.filter((essay) => essay.data.cluster === cluster.slug)
}));
---

<BaseLayout
  title="Theory Clusters"
  description="Clusters that group essays by governing question instead of by timeline."
>
  <section class="section">
    <p class="section-kicker">Theory Clusters</p>
    <h1 class="section-title">A map of the questions behind the writing.</h1>
    <p class="lede">
      The goal is not to publish endlessly. It is to keep related ideas close enough that future
      projects can inherit the reasoning.
    </p>
  </section>

  <section class="cluster-grid">
    {
      clusters.map((cluster) => (
        <article class="card">
          <h2 class="cluster-name">{cluster.name}</h2>
          <p class="card-copy">{cluster.description}</p>
          <p class="cluster-prompt">{cluster.prompt}</p>
          <div class="meta-list">
            {cluster.essays.map((essay) => <span>{essay.data.title}</span>)}
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
