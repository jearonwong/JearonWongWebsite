---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import { theoryClusters } from "../data/site";
---

<BaseLayout title="Ideas & Theory Clusters">
  <div class="zone-a">
    <SiteHeader />
    <section class="shell page-header">
      <span class="eyebrow">Ideas</span>
      <h1 class="page-title">Protocol architecture applied.</h1>
      <p class="lead" style="max-width: 50ch;">
        Core mental models outlining how we govern, constrain, and direct autonomous agents.
      </p>
    </section>
  </div>

  <div class="zone-b page-body">
    <section class="shell section-rhythm">
      <div class="stacked-panels" style="display: flex; flex-direction: column; gap: 0;">
        {theoryClusters.map(cluster => (
          <SignatureIdeaCard {...cluster} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }
  .page-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    max-width: 16ch;
    letter-spacing: -0.04em;
  }
</style>
