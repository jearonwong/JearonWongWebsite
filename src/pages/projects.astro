---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { getProjectBySlug, homepageActions, pageRegistry, siteSemanticBaseline } from "../data/site";

const protocolPathProject = getProjectBySlug("mplp");
const proofPathProjects = ["cognitive-os", "solocrew", "validation-lab"]
  .map((projectSlug) => getProjectBySlug(projectSlug))
  .filter((project): project is NonNullable<ReturnType<typeof getProjectBySlug>> => Boolean(project));
const projectBoundaryNotes = [
  "MPLP is the lifecycle protocol path, not the proof path.",
  "Cognitive OS is a runtime path, not a completed universal runtime.",
  "SoloCrew is a delivery proof path, not finished commercial proof.",
  "Validation Lab is MPLP evidence adjudication, not a credentialing body or general validation service."
];
---

<BaseLayout
  title={pageRegistry.projects.title}
  description={pageRegistry.projects.lead}
  ogImagePath="/social/og-projects.png"
  ogImageAlt="Projects — Evidence Ledger by Jearon Wong"
>
  <RegistryPageHero
    title={pageRegistry.projects.title}
    objectType={pageRegistry.projects.objectType}
    objectValue={pageRegistry.projects.objectValue}
    lead={pageRegistry.projects.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell">

      <!-- Opening: thesis band — dark, authoritative, like lifecycle -->
      <section class="registry-chassis proof-room-thesis">
        <div class="registry-annotation section-tag">
          <span class="registry-key">01_EVIDENCE_LEDGER</span>
        </div>
        <h2>Proof room for the AI Agent Lifecycle mainline.</h2>
        <p class="thesis-lead">{siteSemanticBaseline.referencePathDefinition}</p>
        <div class="scope-ledger" aria-label="Project maturity boundaries">
          {projectBoundaryNotes.map((note, index) => (
            <div class="scope-row">
              <span class="scope-index">{String(index + 1).padStart(2, "0")}</span>
              <p>{note}</p>
            </div>
          ))}
        </div>
        <div class="proof-room-actions">
          <a href="/lifecycle/" class="proof-action-link">Start with AI Agent Lifecycle</a>
          <a href="/essays/" class="proof-action-link">{homepageActions.essays.label}</a>
          <a href="/projects/mplp/" class="proof-action-link">Open the protocol path: MPLP</a>
        </div>
      </section>

      <!-- Protocol Path -->
      <section class="project-section">
        <div class="section-header">
          <div class="registry-annotation section-tag">
            <span class="registry-key">02_PROTOCOL_PATH</span>
          </div>
          <h2>Protocol Path</h2>
          <p class="section-desc">MPLP is the lifecycle protocol path. It is not the proof path.</p>
        </div>
        <div class="protocol-ledger">
          {protocolPathProject && (
            <ProjectProofCard
              {...protocolPathProject}
              href={`/projects/${protocolPathProject.slug}/`}
              linkLabel="Open the protocol path"
              variant="protocol"
            />
          )}
        </div>
      </section>

      <!-- Proof Path -->
      <section class="project-section">
        <div class="section-header">
          <div class="registry-annotation section-tag">
            <span class="registry-key">03_PROOF_PATH</span>
          </div>
          <h2>Proof Path</h2>
          <p class="section-desc">Cognitive OS, SoloCrew, and Validation Lab are the concrete proof path through Agentic Delivery.</p>
        </div>
        <div class="proof-ledger">
          {proofPathProjects.map((project) => (
            <div class="ledger-item" id={project.slug}>
              <ProjectProofCard
                {...project}
                href={`/projects/${project.slug}/`}
                variant="ledger-row"
              />
            </div>
          ))}
        </div>
      </section>

    </section>
  </div>
</BaseLayout>

<style>
  /* ── Opening Thesis Band ── */
  .proof-room-thesis {
    padding: var(--registry-panel-padding);
    border-left: 4px solid var(--accent-signal);
    background: #111111;
    --current-surface: #111111;
    --current-border: rgba(255, 255, 255, 0.1);
    --current-line: rgba(255, 255, 255, 0.08);
    --current-muted: rgba(226, 232, 240, 0.68);
    --current-text: #f1f5f9;
    color: var(--current-text);
    margin-bottom: var(--space-5);
  }

  .section-tag {
    margin-bottom: 1rem;
  }

  .proof-room-thesis h2 {
    margin: 0;
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .thesis-lead {
    max-width: 55rem;
    margin: 1.1rem 0 0;
    color: var(--current-muted);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.6;
  }

  /* ── Scope Ledger (boundary notes as indexed rows) ── */
  .scope-ledger {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--current-line);
  }

  .scope-row {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr);
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--current-line);
    align-items: start;
  }

  .scope-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .scope-index {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--accent-signal);
    padding-top: 0.2em;
  }

  .scope-row p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--current-muted);
  }

  /* ── Action Links ── */
  .proof-room-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.2rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--current-line);
  }

  .proof-action-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }

  .proof-action-link:hover {
    color: #f1f5f9;
  }

  /* ── Sections ── */
  .project-section {
    display: grid;
    gap: 1.35rem;
    margin-top: var(--space-8);
  }

  .section-header {
    display: grid;
    gap: 0.6rem;
  }

  .section-header h2 {
    margin: 0;
    color: var(--current-text);
    font-size: clamp(1.6rem, 3vw, 2.15rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .section-desc {
    max-width: 64ch;
    margin: 0;
    color: var(--current-muted);
    font-size: 0.98rem;
    line-height: 1.62;
  }

  /* ── Protocol Ledger: MPLP dark authority ── */
  .protocol-ledger {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .protocol-ledger :global(.variant-protocol) {
    background: #111111;
    --current-surface: #111111;
    --current-border: rgba(255, 255, 255, 0.1);
    --current-line: rgba(255, 255, 255, 0.08);
    --current-muted: rgba(226, 232, 240, 0.68);
    --current-text: #f1f5f9;
  }

  /* ── Proof Ledger: essays log-entry rhythm ── */
  .proof-ledger {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--current-line);
  }

  .ledger-item {
    display: block;
  }

  .ledger-item:not(:last-child) {
    border-bottom: 1px solid var(--current-line);
  }

  /* Inherit essays series border treatment + bolder title */
  .proof-ledger :global(.variant-ledger-row) {
    border-left: 2px solid var(--accent-proof);
  }

  .proof-ledger :global(.variant-ledger-row .record-title) {
    font-size: clamp(1.4rem, 2.5vw, 1.72rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .proof-room-thesis {
      padding: var(--registry-card-padding);
      margin-bottom: var(--space-4);
    }

    .project-section {
      margin-top: var(--space-5);
    }
  }

  @media (max-width: 640px) {
    .scope-row {
      grid-template-columns: 2.5rem minmax(0, 1fr);
    }
  }
</style>
