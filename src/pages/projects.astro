---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { projects } from "../data/site";
---

<BaseLayout title="Projects & Proof">
  <div class="zone-a">
    <SiteHeader />
    <section class="shell page-header">
      <span class="eyebrow">Projects</span>
      <h1 class="page-title">Evidence of thinking made concrete.</h1>
      <p class="lead" style="max-width: 50ch;">
        We do not build portfolios. We build proof that the protocol and cognitive architecture actually work in delivery.
      </p>
    </section>
  </div>

  <div class="zone-b page-body">
    <section class="shell section-rhythm">
      <div class="stacked-panels proof-panels" style="display: flex; flex-direction: column; gap: 2rem;">
        {projects.map(project => (
          <ProjectProofCard {...project} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }
  .page-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    max-width: 16ch;
    letter-spacing: -0.04em;
  }
</style>
