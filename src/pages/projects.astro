---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { projects } from "../data/site";
import { siteConfig } from "../data/site";
---

<BaseLayout title={`Ledger | ${siteConfig.title}`}>
  <div class="zone-a registry-grid" style="padding-top: 10rem; padding-bottom: 6rem; border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    <div class="shell">
      <div class="registry-annotation" style="margin-bottom: 1rem;">
        <span class="registry-key">OBJECT_TYPE</span>: <span class="registry-value">EVIDENCE_LEDGER</span>
      </div>
      <h1 style="font-size: 4rem; font-weight: 800; letter-spacing: -0.04em;">PROOFS & RECORDS</h1>
      <p class="lead" style="max-width: 50ch;">Artifacts of thinking made concrete. Each entry is a verification point for the protocol architecture.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="card-grid">
        {projects.map(project => (
          <ProjectProofCard {...project} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
    gap: 3rem;
  }
  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
