---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { siteConfig } from "../../data/site";

export async function getStaticPaths() {
  const essays = await getCollection("essays");

  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay }
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();
---

<BaseLayout title={`${essay.data.title} | ${siteConfig.title}`} description={essay.data.description}>
  <div class="zone-a registry-grid" style="padding-top: 10rem; padding-bottom: 6rem; border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    <div class="shell">
      <div class="registry-annotation" style="margin-bottom: 1.5rem;">
        <span class="registry-key">ENTRY_ID</span>: <span class="registry-value">{essay.slug.toUpperCase()}</span> // 
        <span class="registry-key">DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
      </div>
      <h1 style="font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 800; letter-spacing: -0.04em; margin-bottom: 1.5rem;">{essay.data.title}</h1>
      <p class="lead" style="max-width: 60ch; color: var(--text-registry-muted);">{essay.data.description}</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <article class="shell article-shell">
      <div class="article-content prose">
        <Content />
      </div>
      
      <div class="registry-chassis" style="margin-top: 6rem; padding: 2rem; border-left: 2px solid var(--accent-signal);">
        <div class="registry-annotation" style="margin-bottom: 0.5rem;">
          <span class="registry-key">CROSS_REFERENCE</span>
        </div>
        <div class="registry-annotation">
          <span class="registry-key">CLUSTER</span>: <span class="registry-value">{essay.data.cluster}</span> // 
          <span class="registry-key">PROOF</span>: <span class="registry-value">{essay.data.projectProof}</span>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .article-shell {
    max-width: 800px;
    margin: 0 auto;
  }
  .article-content {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--current-text);
  }
  .article-content :global(h2) {
    font-size: 2rem;
    font-weight: 800;
    margin: 4rem 0 1.5rem 0;
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 0.5rem;
  }
  .article-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem 0;
  }
  .article-content :global(p) {
    margin-bottom: 1.8rem;
  }
  .article-content :global(blockquote) {
    border-left: 2px solid var(--accent-signal);
    background-color: rgba(59, 130, 246, 0.03);
    padding: 2rem;
    margin: 3rem 0;
    font-style: italic;
    color: var(--current-muted);
  }
  .article-content :global(a) {
    color: var(--accent-signal);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
