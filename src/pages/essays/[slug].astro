---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const essays = await getCollection("essays");

  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay }
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();
---

<BaseLayout title={essay.data.title} description={essay.data.description} ogType="article">
  <article class="article-shell">
    <a href="/essays" class="back-link">← Back to essays</a>
    <p class="eyebrow">{essay.data.publishDate.toLocaleDateString("en-US", { dateStyle: "long" })}</p>
    <h1>{essay.data.title}</h1>
    <p class="lede">{essay.data.description}</p>
    <div class="meta-list">
      <span>{essay.data.cluster}</span>
      <span>{essay.data.projectProof}</span>
    </div>
    <p class="article-note">
      This essay belongs to a theory cluster and names the kind of project evidence it is meant to
      support.
    </p>
    <Content />
  </article>
</BaseLayout>
