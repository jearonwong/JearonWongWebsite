---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryPageHero from "../../components/RegistryPageHero.astro";
import { aiAgentLifecycleColumn, getTheoryClusterName, pageRegistry } from "../../data/site";

const essays = (await getCollection("essays")).sort(
  (left, right) =>
    Number(right.data.flagship) - Number(left.data.flagship) ||
    right.data.publishDate.getTime() - left.data.publishDate.getTime()
);
---

<BaseLayout title="Essays" description={pageRegistry.essays.lead}>
  <RegistryPageHero
    title={pageRegistry.essays.title}
    objectType={pageRegistry.essays.objectType}
    objectValue={pageRegistry.essays.objectValue}
    lead={pageRegistry.essays.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis lifecycle-spotlight">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">LIFECYCLE_PROTOCOL_SPOTLIGHT</span>: <span class="registry-value">{aiAgentLifecycleColumn.seriesTitle.toUpperCase()}</span>
        </div>
        <div class="lifecycle-spotlight-grid">
          <div>
            <h2 class="spotlight-title">{aiAgentLifecycleColumn.categoryTitle}</h2>
            <p class="spotlight-copy">{aiAgentLifecycleColumn.categoryStatement}</p>
            <p class="spotlight-relation">{aiAgentLifecycleColumn.relationToAgenticDelivery}</p>
          </div>
          <div class="spotlight-actions">
            <p>{aiAgentLifecycleColumn.publicationRule}</p>
            <a href={aiAgentLifecycleColumn.href} class="spotlight-link">Open the Lifecycle Protocol entry</a>
          </div>
        </div>
      </div>

      <div class="registry-section-heading">
        <div class="registry-annotation" style="margin-bottom: 0.65rem;">
          <span class="registry-key">PUBLISHED_ESSAYS</span>: <span class="registry-value">REGISTRY</span>
        </div>
        <h2>Published Essays Registry</h2>
      </div>

      <div class="registry-log">
        {essays.map((essay) => (
          <article class:list={["log-entry", essay.data.flagship && "is-flagship"]}>
            <div class="log-metadata">
              {essay.data.flagship && (
                <div class="registry-annotation log-flagship">
                  <span class="registry-key">START_HERE</span>: <span class="registry-value">FLAGSHIP ESSAY</span>
                </div>
              )}
              <div class="registry-annotation">
                <span class="registry-key">ENTRY_DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
              </div>
              <div class="registry-annotation">
                <span class="registry-key">IDEA</span>: <span class="registry-value">{getTheoryClusterName(essay.data.cluster).toUpperCase()}</span>
              </div>
            </div>
            <div class="log-content">
              <h3 class="log-title"><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
              <p class="log-desc">{essay.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .lifecycle-spotlight {
    margin-bottom: 2rem;
    padding: 2rem;
    border-left: 2px solid var(--accent-proof);
  }
  .lifecycle-spotlight-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(260px, 0.85fr);
    gap: 2rem;
  }
  .spotlight-title {
    margin: 0 0 0.7rem;
    font-size: 1.8rem;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .spotlight-copy,
  .spotlight-relation,
  .spotlight-actions p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--current-muted);
  }
  .spotlight-relation {
    margin-top: 0.9rem;
    color: var(--current-text);
  }
  .spotlight-actions {
    display: grid;
    align-content: start;
    gap: 1rem;
  }
  .spotlight-link {
    display: inline-flex;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .spotlight-link:hover {
    color: var(--current-text);
  }
  .registry-section-heading {
    margin: 0 0 1.4rem;
  }
  .registry-section-heading h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .registry-log {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--current-line);
  }
  .log-entry {
    display: grid;
    grid-template-columns: 280px 1fr;
    padding: 3rem;
    border-bottom: 1px solid var(--current-line);
    transition: background-color 0.25s ease;
  }
  .log-entry:last-child {
    border-bottom: none;
  }
  .log-entry:hover {
    background-color: rgba(59, 130, 246, 0.03);
  }
  .log-entry.is-flagship {
    border-left: 2px solid var(--accent-signal);
  }
  .log-metadata {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .log-flagship {
    color: var(--accent-signal);
  }
  .log-title {
    font-size: 1.72rem;
    font-weight: 800;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .log-title a {
    color: var(--current-text);
    text-decoration: none;
  }
  .log-title a:hover {
    color: var(--accent-signal);
  }
  .log-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
    max-width: 62ch;
    margin: 0;
  }
  @media (max-width: 900px) {
    .lifecycle-spotlight {
      padding: 1.5rem;
    }
    .lifecycle-spotlight-grid {
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }
    .spotlight-title {
      font-size: 1.45rem;
    }
    .log-entry {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      padding: 1.75rem;
    }
    .log-metadata {
      gap: 0.65rem;
    }
    .log-title {
      font-size: 1.4rem;
    }
    .log-desc {
      font-size: 0.95rem;
    }
  }
</style>
