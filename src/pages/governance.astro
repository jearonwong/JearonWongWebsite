---
import { siteConfig } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<BaseLayout title={`Governance | ${siteConfig.title}`}>
  <div class="zone-a registry-grid" style="padding-top: 10rem; padding-bottom: 6rem; border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    <div class="shell">
      <div class="registry-annotation" style="margin-bottom: 1rem;">
        <span class="registry-key">OBJECT_TYPE</span>: <span class="registry-value">SYSTEM_GOVERNANCE_APPENDIX</span>
      </div>
      <h1 style="font-size: 4rem; font-weight: 800; letter-spacing: -0.04em;">GOVERNANCE</h1>
      <p class="lead" style="max-width: 50ch;">The fundamental operating procedures and compliance checks for the Cognitive OS.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis" style="padding: 4rem;">
        <div class="registry-annotation" style="margin-bottom: 2rem;">
          <span class="registry-key">APPENDIX_ID</span>: <span class="registry-value">GOV_SUBSTRATE_01</span>
        </div>
        <div class="prose" style="max-width: 65ch; font-size: 1.1rem; line-height: 1.7; color: var(--current-muted);">
          <p>Governance is the binding layer. It defines how autonomous agents are constrained, how they are audited, and how they report state changes back to the human architect.</p>
          <div class="registry-chassis" style="margin-top: 3rem; padding: 2rem; border-left: 2px solid var(--accent-signal);">
             <div class="registry-annotation" style="margin-bottom: 0.5rem;">
               <span class="registry-key">STATUS</span>: <span class="registry-value">DRAFT_PHASE</span>
             </div>
             <p style="margin: 0;">Full governance specifications are currently being refined for the v0.4 release.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
