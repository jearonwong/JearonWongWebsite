---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PortraitAnchor from "../components/PortraitAnchor.astro";
import ImmediateProofSignal from "../components/ImmediateProofSignal.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { homepageActions, siteConfig, projects, socialLinks } from "../data/site";

const essays = (await getCollection("essays"))
  .sort((left, right) =>
    Number(right.data.flagship) - Number(left.data.flagship) ||
    right.data.publishDate.getTime() - left.data.publishDate.getTime()
  )
  .slice(0, 3);

const flagshipEssay = essays.find(e => e.data.flagship) || essays[0];

const writingTracks = [
  { name: "Protocol Engineering", desc: "Lifecycle vocabulary, handoff semantics, and delivery grammar for agent systems." },
  { name: "Reliable Agent Delivery", desc: "How agent systems complete real work — plannable, verifiable, and auditable." },
  { name: "Agent Governance & Evidence", desc: "Oversight structures, compliance surfaces, and accountability frameworks for autonomous work." },
  { name: "AI Programming & Delivery Systems", desc: "Runtime architecture, state management, and operating constraints for protocol-aware agents." },
  { name: "Agent Stack Commentary", desc: "Analysis and perspective on the evolving agent infrastructure landscape." }
];
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <!-- 1. Person + Thesis (Hero) -->
  <div class="zone-a registry-grid hero-wrapper" style="border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    
    <section class="shell hero-section">
      <div class="split-layout">
        <div class="hero-content">
          <h1 class="hero-nameplate">{siteConfig.author.name}</h1>
          <p class="hero-thesis">{siteConfig.thesis}</p>
          <p class="hero-role-line">{siteConfig.author.role}</p>
          <p class="hero-support">{siteConfig.supportLine}</p>
          
          <div class="hero-ctas">
            <a href={homepageActions.thesis.href} class="button button-primary">{homepageActions.thesis.label}</a>
            <a href={homepageActions.projects.href} class="button button-outline" style="border: 1px solid var(--border-registry); background: rgba(255,255,255,0.05);">{homepageActions.projects.label}</a>
          </div>

          <div class="proof-signal-band">
            <ImmediateProofSignal />
          </div>
        </div>
        <div class="hero-visual">
          <PortraitAnchor />
        </div>
      </div>
    </section>
  </div>

  <!-- 2. Why Now (Narrative Band) — standalone dark zone, not inside zone-b -->
  <section class="zone-a registry-grid narrative-band">
    <div class="shell" style="max-width: 900px; text-align: left;">
      <h2 class="narrative-lead">
        The industry focused on models and tools. 
        <br/>The missing layer is <span style="color: var(--accent-proof);">reliable work delivery</span>.
      </h2>
      <div class="narrative-support">
        <p class="lead" style="margin: 0; color: var(--text-registry-muted);">
          Prompt Engineering controls expression. Context Engineering controls what models see. Protocol Engineering controls the evidence of delivery.
        </p>
      </div>
    </div>
  </section>

  <div class="zone-b page-body">

    <!-- 3. Proof Chain -->
    <section id="proof" class="shell section-rhythm">
      <div class="section-header">
        <h2>The proof chain.</h2>
        <p class="section-desc">Each project carries a different architectural claim. Together they form an evidence chain for reliable agent delivery.</p>
        <a href={homepageActions.proof.href} class="section-link">{homepageActions.proof.label}</a>
      </div>
      <div class="card-grid">
        {projects.map(project => (
          <ProjectProofCard
            {...project}
            href={`/projects/${project.slug}/`}
          />
        ))}
      </div>
    </section>

    <!-- 4. Flagship Essay -->
    {flagshipEssay && (
      <section class="shell section-rhythm" style="padding-top: 2rem;">
        <div class="section-header">
          <h2>The thesis essay.</h2>
          <p class="section-desc">The foundational argument — why the industry needs Protocol Engineering.</p>
        </div>
        <article class="flagship-card">
          <div class="flagship-content">
            <h3><a href={`/essays/${flagshipEssay.slug}/`}>{flagshipEssay.data.title}</a></h3>
            <p class="muted">{flagshipEssay.data.description}</p>
            <a href={`/essays/${flagshipEssay.slug}/`} class="section-link">Read the full essay</a>
          </div>
        </article>
      </section>
    )}

    <!-- 5. Writing Tracks -->
    <section class="shell section-rhythm" style="padding-top: 2rem;">
      <div class="section-header">
        <h2>Writing tracks.</h2>
        <p class="section-desc">Five lines of inquiry across protocols, governance, runtime, delivery, and product.</p>
        <a href={homepageActions.essays.href} class="section-link">{homepageActions.essays.label}</a>
      </div>
      <div class="tracks-grid">
        {writingTracks.map(track => (
          <div class="track-item">
            <h4 class="track-name">{track.name}</h4>
            <p class="track-desc">{track.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 6. Contact / Signal -->
    <section class="shell section-rhythm quiet-close" style="padding-top: 2rem;">
      <div class="close-content">
        <h2>Get in touch.</h2>
        <p class="section-desc">For industry dialogue, advisory, collaboration, or media.</p>
        <div class="close-actions">
          <a href={`mailto:${siteConfig.author.email}`} class="button button-primary" style="background: #111; color: #fff;">{siteConfig.author.email}</a>
          <div class="close-social">
            {socialLinks.map(link => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-pill">{link.platform}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-wrapper {
    position: relative;
    overflow: hidden;
  }
  .hero-section {
    padding-top: 4.85rem;
    padding-bottom: 5.5rem;
  }
  .hero-nameplate {
    font-size: clamp(2.35rem, 4.8vw, 3rem);
    font-weight: 820;
    letter-spacing: -0.05em;
    line-height: 0.96;
    margin-bottom: 1.5rem;
    color: var(--text-registry-primary);
    max-width: 12ch;
  }
  .hero-thesis {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 750;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 0.75rem;
    color: var(--text-registry-primary);
    max-width: 22ch;
  }
  .hero-role-line {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-registry-muted);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }
  .hero-support {
    max-width: 44ch;
    color: var(--text-registry-muted);
    font-size: 1.05rem;
    line-height: 1.65;
    font-weight: 400;
    margin-bottom: 2.25rem;
  }
  .proof-signal-band {
    margin-top: 2.25rem;
    padding: 1.25rem 1.5rem;
    background-color: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-registry);
    border-left: 3px solid var(--accent-signal);
    max-width: 34rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  /* ── Sections ── */
  .section-header h2 {
    font-size: clamp(1.8rem, 3.2vw, 2.35rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin-bottom: 0.6rem;
  }
  .section-desc {
    font-size: 1rem;
    color: var(--current-muted);
    line-height: 1.6;
    max-width: 55ch;
    margin-bottom: 0.25rem;
  }
  .section-link {
    display: inline-flex;
    align-items: center;
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .section-link:hover {
    color: var(--current-text);
  }
  .section-header {
    margin-bottom: 3.5rem;
  }

  /* ── Narrative Band ── */
  .narrative-band {
    padding: 6rem 0;
    border-top: 1px solid var(--border-registry);
    border-bottom: 1px solid var(--border-registry);
  }
  .narrative-lead {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 2rem;
    font-weight: 800;
  }
  .narrative-support {
    padding: 1.5rem;
    border-left: 2px solid var(--accent-proof);
  }

  /* ── Card Grid ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* ── Flagship ── */
  .flagship-card {
    background: var(--current-surface);
    border: 1px solid var(--current-border);
    border-left: 4px solid var(--accent-signal);
    border-radius: var(--radius-module);
    padding: 2.5rem;
  }
  .flagship-content h3 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .flagship-content h3 a {
    color: inherit;
    text-decoration: none;
  }
  .flagship-content h3 a:hover {
    color: var(--accent-signal);
  }
  .flagship-content .muted {
    color: var(--current-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: 1rem;
  }

  /* ── Writing Tracks ── */
  .tracks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0;
  }
  .track-item {
    padding: 1.5rem 1.5rem 1.5rem 0;
    border-bottom: 1px solid var(--current-line);
  }
  .track-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent-signal);
    margin-bottom: 0.5rem;
  }
  .track-desc {
    font-size: 0.9rem;
    color: var(--current-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Quiet Close ── */
  .quiet-close {
    padding-bottom: 2rem;
  }
  .close-content h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .close-actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  .close-social {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .social-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--current-muted);
    border: 1px solid var(--current-border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .social-pill:hover {
    border-color: var(--accent-signal);
    color: var(--accent-signal);
  }

  /* ── Layout ── */
  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
    gap: 5rem;
    align-items: start;
  }
  .hero-visual {
    justify-self: end;
    width: min(100%, 22rem);
    padding-top: 1.4rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .split-layout {
      gap: 3rem;
      grid-template-columns: 1fr;
    }
    .hero-visual {
      justify-self: start;
      width: min(100%, 21rem);
      padding-top: 0;
    }
  }

  @media (max-width: 900px) {
    .split-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .hero-section {
      padding-top: 4rem;
      padding-bottom: 4.5rem;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 4.5rem;
      padding-bottom: 4rem;
    }
    .hero-nameplate {
      font-size: clamp(2rem, 9vw, 2.7rem);
    }
    .hero-thesis {
      font-size: clamp(1.3rem, 5.5vw, 1.7rem);
    }
    .hero-support {
      font-size: 0.95rem;
      max-width: 36ch;
    }
    .proof-signal-band {
      margin-top: 2rem;
      padding: 1.1rem 1.25rem;
    }
    .hero-visual {
      width: min(100%, 18rem);
    }
    .section-header {
      margin-bottom: 2.5rem;
    }
    .card-grid {
      gap: 1.25rem;
    }
    .narrative-band {
      padding: 4.5rem 0;
    }
    .tracks-grid {
      grid-template-columns: 1fr;
    }
    .flagship-card {
      padding: 1.75rem;
    }
  }
</style>
