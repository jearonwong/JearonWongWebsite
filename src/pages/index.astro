---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PortraitAnchor from "../components/PortraitAnchor.astro";
import ImmediateProofSignal from "../components/ImmediateProofSignal.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { siteConfig, theoryClusters, projects } from "../data/site";

const essays = (await getCollection("essays"))
  .sort((left, right) => right.data.publishDate.getTime() - left.data.publishDate.getTime())
  .slice(0, 3);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <!-- 1. The Architectural Stage -> Command Center -->
  <div class="zone-a registry-grid hero-wrapper" style="border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    
    <section class="shell hero-section">
      <div class="split-layout">
        <div class="hero-content">
          <div class="registry-annotation" style="margin-bottom: 1.5rem;">
            <span class="registry-key">INIT_SEQUENCE</span>: <span class="registry-value">PROTOCOL_ARCHITECT_CORE</span>
          </div>
          <h1 class="hero-role">JEARON WANG</h1>
          <div class="registry-annotation" style="font-size: 1.1rem; margin-bottom: 2rem;">
            <span class="registry-key">PROPOSITION</span>: <span class="registry-value">DEFINING_RELIABLE_WORK_DELIVERY</span>
          </div>
          <p class="lead" style="max-width: 46ch; color: var(--text-registry-muted);">{siteConfig.thesis}</p>
          
          <div class="hero-ctas">
            <a href="#ledger" class="button button-primary">INSPECT_LEDGER</a>
            <a href="#blueprint" class="button button-outline">OPEN_BLUEPRINT</a>
          </div>

          <div class="registry-chassis" style="margin-top: 4rem; padding: 1.5rem; background-color: rgba(0,0,0,0.3);">
            <div class="registry-annotation" style="margin-bottom: 1rem;">
              <span class="proof-signal-dot"></span>
              <span class="registry-key">ACTIVE_EVIDENCE_STREAM</span>
            </div>
            <ImmediateProofSignal />
          </div>
        </div>
        <div class="hero-visual">
          <PortraitAnchor />
        </div>
      </div>
    </section>
  </div>

  <!-- 2. The Proposition -> Blueprint Zone -->
  <div class="zone-b page-body" style="padding-top: 6rem;">
    
    <section id="blueprint" class="shell section-rhythm">
      <div class="section-header" style="margin-bottom: 5rem; border-left: 4px solid var(--accent-signal); padding-left: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">MODULE</span>: <span class="registry-value">CONCEPTUAL_FRAMEWORK</span>
        </div>
        <h2 style="max-width: 20ch; font-weight: 800; letter-spacing: -0.03em;">Protocol architecture applied to autonomous agents.</h2>
      </div>
      <div class="card-grid">
        {theoryClusters.map(cluster => (
          <SignatureIdeaCard {...cluster} />
        ))}
      </div>
    </section>

    <!-- 3. The Narrative -> System State -->
    <section class="zone-a registry-grid narrative-band" style="padding: 8rem 0; margin: 6rem 0; border-top: 1px solid var(--border-registry); border-bottom: 1px solid var(--border-registry);">
      <div class="shell" style="max-width: 900px; text-align: left;">
        <div class="registry-annotation" style="margin-bottom: 2rem;">
          <span class="registry-key">SYSTEM_OBSERVATION</span>: <span class="registry-value">MARKET_GAP_ANALYSIS</span>
        </div>
        <h2 class="narrative-lead" style="font-size: 3rem; margin-bottom: 3rem;">
          The industry focused on models and tools. 
          <br/>The missing layer is <span style="color: var(--accent-proof);">reliable work delivery</span>.
        </h2>
        <div class="registry-chassis" style="padding: 2rem; border-left: 2px solid var(--accent-proof);">
          <p class="lead" style="margin: 0; color: var(--text-registry-muted);">
            Prompt Engineering controls expression. Context Engineering controls what models see. Protocol Engineering controls the evidence of delivery.
          </p>
        </div>
      </div>
    </section>

    <!-- 4. The Ledger -> Evidence Room -->
    <section id="ledger" class="shell section-rhythm">
      <div class="section-header" style="margin-bottom: 5rem; border-left: 4px solid var(--accent-proof); padding-left: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">MODULE</span>: <span class="registry-value">EVIDENCE_LEDGER</span>
        </div>
        <h2 style="font-weight: 800; letter-spacing: -0.02em;">Thinking made concrete.</h2>
      </div>
      <div class="card-grid">
        {projects.map(project => (
          <ProjectProofCard {...project} />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

    <!-- 5. Editorial Continuation -> Featured Writing -->
    <section class="shell section-rhythm" style="padding-top: 2rem;">
      <div class="section-header">
        <span class="eyebrow">Featured Writing</span>
        <h2>Arguments about governance, memory, and proof.</h2>
      </div>
      <div class="essay-list" style="margin-top: 4rem;">
        {essays.map(essay => (
          <article class="essay-row">
            <span class="essay-date">{essay.data.publishDate.toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
            <div class="essay-content">
              <h3><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
              <p class="muted">{essay.data.description}</p>
              <a href={`/essays/${essay.slug}/`} class="essay-link">Read essay &rarr;</a>
            </div>
          </article>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .hero-wrapper {
    position: relative;
    overflow: hidden;
  }
  .hero-section {
    padding-top: 6rem; /* Push hero down slightly for breathing room from header */
    padding-bottom: 8rem; /* Large drop-off */
  }
  .hero-role {
    /* Typographic Authority */
    text-transform: uppercase;
    font-size: clamp(3.2rem, 7vw, 5rem);
    letter-spacing: -0.05em;
    line-height: 0.95;
    margin-bottom: 1.5rem;
    max-width: 10ch; /* Forces the exact wrapping */
    font-weight: 800;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }
  
  .section-header h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .narrative-lead {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 1.5rem 0 2.5rem;
    font-weight: 800; /* High pressure */
  }
  .narrative-lead em {
    font-style: italic;
    color: var(--zone-a-text);
  }
  .hero-divider {
    width: 100%;
    max-width: 400px;
    margin: 4rem 0 1.5rem 0;
    border: none;
    border-top: 1px solid var(--zone-a-border);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }
  .essay-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    padding: 3rem 0;
    border-top: 1px solid var(--zone-b-line);
  }
  .essay-row:last-child {
    border-bottom: 1px solid var(--zone-b-line);
  }
  .essay-date {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--zone-b-muted);
    padding-top: 0.4rem;
  }
  .essay-content h3 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }
  .essay-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-top: 1rem;
    color: var(--current-text);
  }
  
  /* Split layout control for hero */
  .split-layout {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr; /* Give more width to text declarations, keeping Portrait bound */
    gap: 6rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .split-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .hero-section {
      padding-top: 4rem;
      padding-bottom: 5rem;
    }
  }
  
  @media (max-width: 768px) {
    .essay-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 2rem 0;
    }
  }
</style>
